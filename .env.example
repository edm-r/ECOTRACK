# ── Database ──────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ecotrack
POSTGRES_USER=ecotrack
# Remplacer par un mot de passe fort en production
POSTGRES_PASSWORD=ChangeMeInProduction!

# ── Backend ───────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
SECRET_KEY=a8f3e2c7d1b945f0e6a2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Redis (optional) ──────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MQTT / IoT Simulator ──────────────────────────────────
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_USERNAME=ecotrack
MQTT_PASSWORD=ChangeMeInProduction!
# Générer avec : openssl rand -hex 24
IOT_SERVICE_TOKEN=ecotrack-iot-token-change-in-production-with-openssl-rand
IOT_SIMULATE_INTERVAL_SECONDS=15
IOT_CONTAINERS_COUNT=100

# ── Frontend ──────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
